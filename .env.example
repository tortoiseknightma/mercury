# DashScope (Aliyun) - OpenAI-compatible endpoint
DASHSCOPE_API_KEY=sk-xxx
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Default model identifiers (used as fallbacks for the per-role overrides below).
QWEN_PLUS_MODEL=qwen-plus
QWEN_FLASH_MODEL=qwen-flash

# Per-role model assignments.  Each falls back to QWEN_PLUS_MODEL (or
# QWEN_FLASH_MODEL for `FLASH_MODEL`) when unset, so leaving them blank
# preserves the historical "qwen-plus everywhere" behaviour.
#
# A useful asymmetry:  point EXECUTOR_MODEL at a *weaker* model (e.g.
# qwen-flash / qwen-turbo) so traces are long enough for the evaluator to find
# a reusable pattern, while keeping the evaluator on a smarter model so its
# reflection is high-quality.  The verifier's probe runs always reuse
# EXECUTOR_MODEL (otherwise the 0.85× token budget vs. baseline_metrics is
# meaningless).
# EXECUTOR_MODEL=qwen-flash
# EVALUATOR_MODEL=qwen-plus
# FLASH_MODEL=qwen-flash

# Agent harness hyperparameters
MAX_STEPS=12
EXECUTOR_TEMPERATURE=0.0
EVALUATOR_TEMPERATURE=0.3

# Docker sandbox
SANDBOX_IMAGE=mercury-sandbox:latest
SANDBOX_MEM_LIMIT=512m
SANDBOX_CPU_LIMIT=1.0
SANDBOX_TIMEOUT_SECONDS=30
